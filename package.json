{
  "name": "hbl-automation-cucumber",
  "version": "1.0.0",
  "description": "Playwright automation using cucumber BDD",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "cucumber-js --config cucumber.js",
    "test:headed": "cross-env HEADED=true cucumber-js --config cucumber.js",
    "test:login": "cucumber-js --config cucumber.js --tags '@login'",
    "test:payee": "cucumber-js --config cucumber.js --tags '@payee'",
    "report:cucumber": "node scripts/generate-manager-report.js"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "gherkin",
    "typescript",
    "hbl"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@playwright/test": "^1.55.0",
    "@types/node": "^25.5.0",
    "cross-env": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "dotenv": "^17.4.1"
  }
}
